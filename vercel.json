{
  "functions": {
    "api/index.py": {
      "includeFiles": [
        "routes/**",
        "templates/**",
        "static/**",
        "app.py",
        "extensions.py",
        "models.py"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ]
}